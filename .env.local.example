# .env.local template
# Copy ke .env.local dan fill dengan nilai yang sesuai

# ===================================
# DATABASE CONFIGURATION
# ===================================
# Untuk Laragon default:
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=(kosong)
# DB_PORT=3306

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=db_filkommerch
DB_PORT=3306

# ===================================
# MIDTRANS CONFIGURATION
# ===================================
# Sandbox credentials untuk testing
MIDTRANS_SERVER_KEY=YOUR_MIDTRANS_SERVER_KEY
MIDTRANS_CLIENT_KEY=YOUR_MIDTRANS_SERVER_KEY

# ===================================
# API CONFIGURATION
# ===================================
VITE_API_URL=http://localhost:5173/api
